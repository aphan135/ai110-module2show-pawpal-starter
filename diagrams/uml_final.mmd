classDiagram
    class ScheduleConstraints {
        - int available_minutes
        - Optional[int] max_tasks
        - List[PriorityLevel] priority_order
        - List[str] preferred_categories
        - Optional[time] available_start
        - Optional[time] available_end
    }

    class Task {
        - String title
        - String description
        - int duration_minutes
        - PriorityLevel priority
        - boolean recurring
        - String category
        - Optional[date] scheduled_date
        - Optional[time] preferred_start_time
        - boolean completed
        - String frequency
        + is_high_priority()
        + summary()
        + get_next_occurrence_date()
        + create_next_occurrence()
        + mark_complete(pet)
    }

    class Pet {
        - String name
        - String species
        - int age
        - String breed
        - String care_notes
        - List[Task] tasks
        + add_task(task)
        + remove_task(task)
        + get_daily_tasks(target_date)
    }

    class OwnerPreferences {
        - int available_minutes_per_day
        - Optional[int] max_tasks_per_day
        - List[PriorityLevel] preferred_task_order
        - List[str] category_preferences
    }

    class Owner {
        - String name
        - String contact_info
        - List[Pet] pets
        - OwnerPreferences preferences
        + add_pet(pet)
        + remove_pet(pet)
        + update_preferences(preferences)
        + get_all_tasks()
        + get_daily_tasks(target_date)
    }

    class Scheduler {
        - Owner owner
        - Optional[date] target_date
        - ScheduleConstraints constraints
        - List[Task] planned_tasks
        + retrieve_all_tasks()
        + retrieve_daily_tasks()
        + sort_tasks(tasks)
        + sort_by_time(tasks)
        + filter_tasks(completed, pet_name)
        + find_time_conflicts(tasks)
        + generate_plan()
        + get_total_duration()
        + explain_plan()
        + mark_task_complete(task)
        + add_task_to_pet(pet, task)
        + update_constraints(constraints)
    }

    Owner "1" --> "many" Pet
    Owner "1" --> "1" OwnerPreferences
    Pet "1" --> "many" Task
    Scheduler "1" --> "1" Owner
    Scheduler "1" --> "1" ScheduleConstraints
    Scheduler "1" --> "many" Task : plans
